const RENOVATION_STAGES=[{id:"preparation",name:"前期准备",icon:"📋",order:1,description:"装修的第一步，包括量房、确定装修风格、寻找靠谱设计师、办理装修许可证等。这一阶段决定了整个装修的方向和预算框架。",duration:"2-4周",tasks:[{id:"prep-t1",text:"实地量房并绘制户型图",detail:"用卷尺或激光测距仪精确测量每个房间的长、宽、高，记录门窗位置和尺寸，标注承重墙与非承重墙，绘制详细户型图。"},{id:"prep-t2",text:"确定装修风格和需求清单",detail:"全家人一起讨论生活习惯和审美偏好，在小红书、好好住等平台收集灵感图，明确现代简约、北欧、日式、新中式等风格方向。"},{id:"prep-t3",text:"制定装修预算总框架",detail:"根据房屋面积和装修档次，估算总预算。一般经济型800元/㎡，舒适型1500元/㎡，品质型2500元/㎡以上。预留10%-15%的应急资金。"},{id:"prep-t4",text:"选择装修模式",detail:"了解清包（自己买所有材料）、半包（施工方包辅材和人工）、全包（施工方包主材辅材和人工）三种模式的优缺点，根据自身时间和精力选择。"},{id:"prep-t5",text:"寻找并对比装修公司或施工队",detail:"至少对比3家装修公司/施工队，查看营业执照、过往案例、工地实况，与项目经理面谈，索要详细报价单逐项对比。"},{id:"prep-t6",text:"签订装修合同",detail:"合同中必须明确：工期、付款方式（建议3-3-3-1分期）、材料品牌型号、验收标准、违约责任、增项处理方式、保修条款。"},{id:"prep-t7",text:"办理小区装修许可证",detail:"携带房产证、身份证、装修公司营业执照复印件到物业办理装修许可，了解装修时间限制（通常工作日8:00-18:00）、禁止事项等。"},{id:"prep-t8",text:"与邻居提前沟通",detail:"装修前告知楼上楼下及左右邻居，留下联系方式，协商好装修时间。这能避免很多后续纠纷，也是基本礼貌。"}],warnings:[{id:"prep-w1",title:"不要急于开工",detail:"很多人拿到钥匙就想马上装修，但前期准备不充分会导致后期频繁改动，既浪费钱又拖延工期。至少花2周做好规划。"},{id:"prep-w2",title:"合同条款要逐条看",detail:'装修合同中常有模糊条款，如"按实际发生量结算"、"品牌同档次替换"等，这些都是后期加价的陷阱。所有材料必须写明品牌、型号、数量。'},{id:"prep-w3",title:"警惕低价陷阱",detail:"报价远低于市场价的装修公司往往靠后期增项赚钱。常见套路：水电按米报低价后按实际走线大幅超出、故意漏报项目。"},{id:"prep-w4",title:"付款方式要分期",detail:"绝对不要一次性付清全款。建议按进度付款：开工30%、水电完工30%、油漆完工30%、竣工验收10%。"},{id:"prep-w5",title:"不要盲目跟风网红设计",detail:"网红设计好看但不一定实用。岩板大桌、开放式厨房、无主灯设计等要根据自己的生活习惯判断是否适合。"}],shopping:[{id:"prep-s1",name:"激光测距仪",category:"工具",priceMin:80,priceMax:300,unit:"个",note:"精确测量房屋尺寸，比卷尺方便且准确"},{id:"prep-s2",name:"装修设计费",category:"服务",priceMin:50,priceMax:300,unit:"元/㎡",note:"独立设计师收费50-300元/㎡，装修公司设计师可能免费但设计质量参差不齐"},{id:"prep-s3",name:"装修许可证押金",category:"费用",priceMin:500,priceMax:3e3,unit:"次",note:"物业收取的装修保证金，装修完毕验收合格后退还"},{id:"prep-s4",name:"垃圾清运费",category:"费用",priceMin:500,priceMax:2e3,unit:"次",note:"物业收取的建筑垃圾清运费用，部分小区按面积计算"},{id:"prep-s5",name:"户型图打印/设计软件",category:"工具",priceMin:0,priceMax:50,unit:"次",note:"可用酷家乐等免费软件自行设计，也可打印纸质图纸标注"}],preparations:[{id:"prep-p1",text:"准备好房产证、身份证等证件原件及复印件"},{id:"prep-p2",text:"提前了解小区装修管理规定和禁止事项"},{id:"prep-p3",text:"建立装修资金专用账户或记账表格"},{id:"prep-p4",text:"创建装修灵感图册，明确喜好风格"},{id:"prep-p5",text:"列出全家人对新家的功能需求清单"}],workerTypes:[{id:"prep-wk1",name:"独立设计师",priceType:"按面积计费",priceMin:50,priceMax:300,unit:"元/㎡",note:"出全套施工图，含效果图、施工图、水电图等，通常含1-3次现场跟进"},{id:"prep-wk2",name:"量房师",priceType:"按次计费",priceMin:0,priceMax:200,unit:"元/次",note:"很多装修公司和建材商提供免费量房服务"}]},{id:"demolition",name:"拆改阶段",icon:"🔨",order:2,description:"对房屋原有结构进行改造，包括拆除非承重墙、砌新墙、铲除原有墙面涂层、更换门窗等，为后续施工打好基础。",duration:"1-2周",tasks:[{id:"demo-t1",text:"确认承重墙位置并标记",detail:"查阅建筑图纸或请专业人士确认承重墙（通常厚度≥240mm），用醒目标识标记，施工时严禁拆除或开大洞。"},{id:"demo-t2",text:"拆除非承重墙",detail:"按设计图纸拆除需要改动的非承重墙体，从上往下逐步拆除，注意保护周围已有管线和地面。"},{id:"demo-t3",text:"砌筑新墙体",detail:"使用轻质砖或红砖砌新墙，新旧墙交接处需植入钢筋拉结，防止后期开裂。卫生间新砌墙建议使用红砖。"},{id:"demo-t4",text:"铲除原有墙面涂层",detail:"用铲刀或电动铲墙机铲除原有腻子层和涂料层，直到露出水泥砂浆基层。如果原墙面质量好可以保留。"},{id:"demo-t5",text:"拆除原有地面",detail:"如需更换地面材料，拆除原有瓷砖或地板。拆瓷砖时注意不要破坏地面防水层和管线。"},{id:"demo-t6",text:"更换门窗",detail:"如需更换窗户，建议选断桥铝窗（60系列起步），测量尺寸后下单制作，一般需要7-15天制作周期。"},{id:"demo-t7",text:"拆除并清理建筑垃圾",detail:"及时将拆除产生的建筑垃圾装袋运出，堆放在物业指定位置。不要堆在楼道或公共区域。"},{id:"demo-t8",text:"检查并保护原有管线",detail:"拆改前确认墙体和地面内的水管、电线、暖气管位置，拆改过程中做好保护，避免损坏。"}],warnings:[{id:"demo-w1",title:"绝对不能拆承重墙",detail:"拆除承重墙会严重影响建筑结构安全，轻则被物业罚款并要求恢复原状，重则危及整栋楼安全。即使在承重墙上开小门洞也需要结构加固。"},{id:"demo-w2",title:"暖气管道不要随意改动",detail:"集中供暖的暖气管道属于公共系统，私自改动可能影响全楼供暖效果，且出问题后责任自负。改暖气需提前向供暖公司报备。"},{id:"demo-w3",title:"新旧墙体交接处必须挂网",detail:"新砌墙体与原有墙体交接处最容易开裂，必须先植入钢筋拉结，再挂网抹灰处理。这一步省了将来必然开裂。"},{id:"demo-w4",title:"阳台配重墙不能拆",detail:"阳台与房间之间的半截墙（窗台下方的矮墙）通常是配重墙，承担阳台荷载，拆除可能导致阳台下沉或坍塌。"},{id:"demo-w5",title:"拆改前做好成品保护",detail:"入户门、窗框、下水管口、燃气表等不需要拆改的部位要用保护膜包裹好，防止施工过程中磕碰损坏。"},{id:"demo-w6",title:"建筑垃圾要及时清运",detail:"建筑垃圾不能混入生活垃圾，必须单独清运。堆放过久会被物业罚款，也影响后续施工进度。"}],shopping:[{id:"demo-s1",name:"轻质砖/加气块",category:"主材",priceMin:3,priceMax:6,unit:"元/块",note:"砌新墙使用，重量轻隔音一般，卫生间建议用红砖"},{id:"demo-s2",name:"红砖",category:"主材",priceMin:.5,priceMax:1.5,unit:"元/块",note:"卫生间砌墙首选，防潮性能好，承重能力强"},{id:"demo-s3",name:"水泥（P.O 42.5）",category:"辅材",priceMin:25,priceMax:40,unit:"元/袋(50kg)",note:"砌墙和后续泥工都要用，建议选海螺、华润等大品牌"},{id:"demo-s4",name:"河沙/中沙",category:"辅材",priceMin:100,priceMax:200,unit:"元/方",note:"用于砌墙抹灰，注意选中沙（粒径0.35-0.5mm），不要用海沙"},{id:"demo-s5",name:"断桥铝窗户",category:"主材",priceMin:600,priceMax:1500,unit:"元/㎡",note:"含窗框+玻璃+五金+安装，60系列起步，70系列性价比最高"},{id:"demo-s6",name:"植筋胶",category:"辅材",priceMin:20,priceMax:60,unit:"元/支",note:"新旧墙体连接时植入钢筋使用，建议选慧鱼、喜利得等品牌"},{id:"demo-s7",name:"钢筋",category:"辅材",priceMin:4,priceMax:8,unit:"元/米",note:"新旧墙拉结、门洞过梁使用，直径8-10mm"},{id:"demo-s8",name:"成品保护膜",category:"辅材",priceMin:30,priceMax:80,unit:"元/卷",note:"保护入户门、窗框、地漏等成品，用量根据实际面积计算"}],preparations:[{id:"demo-p1",text:"向物业报备开工日期，办理好装修许可证"},{id:"demo-p2",text:"确认承重墙位置，获取建筑结构图纸"},{id:"demo-p3",text:"与楼上楼下邻居沟通装修时间安排"},{id:"demo-p4",text:"准备好成品保护材料，保护入户门和管道"},{id:"demo-p5",text:"联系好建筑垃圾清运服务"}],workerTypes:[{id:"demo-wk1",name:"拆除工人",priceType:"按项目/按天计费",priceMin:300,priceMax:500,unit:"元/天",note:"拆墙、拆地砖等，按天或按项目计费，一般2-3天可完成"},{id:"demo-wk2",name:"砌墙工（瓦工）",priceType:"按面积计费",priceMin:80,priceMax:150,unit:"元/㎡",note:"包含砌墙和抹灰，新旧墙交接植筋另算"},{id:"demo-wk3",name:"门窗安装工",priceType:"含在门窗价格中",priceMin:0,priceMax:0,unit:"元",note:"一般窗户价格已含安装费，复杂安装可能额外收费"},{id:"demo-wk4",name:"垃圾清运",priceType:"按车计费",priceMin:300,priceMax:800,unit:"元/车",note:"小型货车一车约2-3立方米，100㎡房屋拆改约需2-4车"}]},{id:"plumbing_electrical",name:"水电改造",icon:"🔌",order:3,description:"装修中最重要的隐蔽工程，包括水管布线、电路布线、开关插座定位等。水电做好了住几十年不出问题，做差了后患无穷。",duration:"1-2周",tasks:[{id:"pe-t1",text:"与水电工进行详细交底",detail:"拿着设计图纸和水电工逐一确认每个房间的开关、插座、灯具、水龙头位置，现场用粉笔标记所有点位。"},{id:"pe-t2",text:"确定全屋开关插座布局",detail:"根据家具摆放和电器使用习惯规划插座位置和数量。厨房至少8-10个插座，卫生间4-6个，客厅电视墙5-6个，床头两侧各2-3个。"},{id:"pe-t3",text:"水路改造：冷热水管布线",detail:"厨房卫生间水管走顶优于走地（漏水易发现），冷热水管间距15cm，热水管需包保温棉。PPR管建议选日丰、伟星、联塑等品牌。"},{id:"pe-t4",text:"电路改造：强电线路布线",detail:"客厅、卧室照明用2.5平方线，厨房卫生间用4平方线，空调用4平方线（柜机用6平方），入户主线10平方。线管用PVC管，强弱电间距30cm以上。"},{id:"pe-t5",text:"电路改造：弱电线路布线",detail:"网线建议全屋铺设六类线（CAT6），预留光纤入户位置，客厅和主卧预留投影仪线路和音响线路。弱电箱位置合理规划。"},{id:"pe-t6",text:"安装前置过滤器位置预留",detail:"在入户水管处预留前置过滤器安装位置，如果计划装全屋净水系统，需要提前预留所有管路。"},{id:"pe-t7",text:"水电验收并拍照存档",detail:"水路做打压测试（0.8MPa保压30分钟不掉压），电路做绝缘测试。所有管线走向拍照或录视频存档，标注尺寸，方便日后维修。"},{id:"pe-t8",text:"开槽与封槽",detail:"墙面和地面开槽深度和宽度要合理，承重墙开横槽不超过30cm，封槽用水泥砂浆填实抹平。"},{id:"pe-t9",text:"配电箱规划与回路设计",detail:"家庭配电箱建议至少12回路：照明2路、普通插座3-4路、厨房1-2路、卫生间1路、空调2-3路、特殊设备1路。每路配漏电保护或空气开关。"}],warnings:[{id:"pe-w1",title:"水电必须自己盯或请监理",detail:"水电是隐蔽工程，封槽后看不到。一定要在封槽前亲自验收或请第三方监理验收。拍照记录所有管线走向，这是最重要的装修资料。"},{id:"pe-w2",title:"水管走顶比走地好",detail:"水管走地一旦漏水很难发现，等发现时往往已经泡坏了地板和楼下天花。走顶虽然多花一些钱但漏水能第一时间发现。"},{id:"pe-w3",title:"插座宁多勿少",detail:"装修时觉得够用的插座入住后一定不够用。全屋插座建议比预想多留20%-30%，特别是厨房台面、床头、书桌、电视墙。"},{id:"pe-w4",title:"不要用电路接头",detail:"电线管内不能有接头，必须一根线从开关拉到底。接头处是最容易发热和出故障的地方，所有接头必须在接线盒内。"},{id:"pe-w5",title:"热水管一定要包保温棉",detail:"热水管不包保温棉会导致热量散失严重，等热水时间变长，且冬天管道表面会产生冷凝水滴到吊顶上。"},{id:"pe-w6",title:"水电报价要确认计算方式",detail:"水电最常见的增项就是按米计费后实际走线远超预估。开工前要求水电工先弹线量出大致米数，报价差异不应超过10%。"}],shopping:[{id:"pe-s1",name:"PPR水管（冷水管）",category:"水路主材",priceMin:8,priceMax:20,unit:"元/米",note:"建议选伟星、日丰、联塑等品牌，壁厚≥2.3mm"},{id:"pe-s2",name:"PPR水管（热水管）",category:"水路主材",priceMin:12,priceMax:30,unit:"元/米",note:"热水管壁厚≥3.4mm，建议选同品牌配套"},{id:"pe-s3",name:"电线（BV 2.5平方）",category:"电路主材",priceMin:150,priceMax:250,unit:"元/100米",note:"照明和普通插座用，建议选远东、熊猫、正泰等品牌"},{id:"pe-s4",name:"电线（BV 4平方）",category:"电路主材",priceMin:240,priceMax:400,unit:"元/100米",note:"厨房、卫生间大功率回路和挂式空调用"},{id:"pe-s5",name:"电线（BV 6平方）",category:"电路主材",priceMin:350,priceMax:550,unit:"元/100米",note:"柜式空调和即热式热水器专用回路"},{id:"pe-s6",name:"PVC线管（16mm/20mm）",category:"电路辅材",priceMin:2,priceMax:6,unit:"元/米",note:"电线穿管用，16mm走2-3根线，20mm走4-5根线"},{id:"pe-s7",name:"六类网线（CAT6）",category:"弱电材料",priceMin:2,priceMax:5,unit:"元/米",note:"全屋网络布线用，支持千兆网络，选纯铜线芯"},{id:"pe-s8",name:"配电箱（12-16回路）",category:"电路主材",priceMin:150,priceMax:500,unit:"个",note:"建议选施耐德、ABB、正泰等品牌，回路数按实际需求配"},{id:"pe-s9",name:"漏电保护开关",category:"电路主材",priceMin:40,priceMax:150,unit:"个",note:"每个回路一个，建议选施耐德、ABB、西门子等品牌"},{id:"pe-s10",name:"前置过滤器",category:"水路设备",priceMin:200,priceMax:800,unit:"个",note:"安装在入户水管处，过滤泥沙铁锈，保护后端用水设备"},{id:"pe-s11",name:"水管保温棉",category:"水路辅材",priceMin:2,priceMax:5,unit:"元/米",note:"热水管必须包裹，冷水管在吊顶内也建议包裹防冷凝水"},{id:"pe-s12",name:"86型底盒",category:"电路辅材",priceMin:1,priceMax:3,unit:"元/个",note:"开关插座暗装底盒，按开关插座数量1:1购买"}],preparations:[{id:"pe-p1",text:"确认全屋家具、电器布局方案，确定插座点位"},{id:"pe-p2",text:"确认是否需要安装全屋净水、新风、中央空调等系统"},{id:"pe-p3",text:"购买好水管和电线等主材（如自购）"},{id:"pe-p4",text:"准备好设计图纸上的水电点位图"},{id:"pe-p5",text:"了解小区供电容量和入户线径"}],workerTypes:[{id:"pe-wk1",name:"水电工",priceType:"按米计费（包工）",priceMin:35,priceMax:80,unit:"元/米",note:"含开槽、布线、封槽，水路和电路通常分开计费。100㎡全改约150-250米线"},{id:"pe-wk2",name:"水电工",priceType:"按天计费",priceMin:350,priceMax:600,unit:"元/天",note:"适合小范围改动，按天计费比按米便宜但要盯紧进度"},{id:"pe-wk3",name:"水电工",priceType:"按点位计费",priceMin:80,priceMax:200,unit:"元/点位",note:"一个开关或一个插座算一个点位，一个冷热水口算两个点位"}]},{id:"masonry",name:"泥瓦工程",icon:"🧱",order:4,description:"包括卫生间厨房阳台防水施工、墙地砖铺贴、过门石安装、地漏安装等工作。防水是重中之重，必须认真对待。",duration:"2-3周",tasks:[{id:"mas-t1",text:"卫生间防水施工",detail:"卫生间地面全做防水，墙面淋浴区防水高度至少1.8米，其他墙面至少30cm。建议涂刷2-3遍，每遍交叉涂刷，总厚度≥1.5mm。"},{id:"mas-t2",text:"厨房和阳台防水施工",detail:"厨房地面和墙面返高30cm做防水，阳台地面做防水并向地漏方向找坡。有地暖的区域先做防水再做地暖。"},{id:"mas-t3",text:"闭水试验（蓄水试验）",detail:"防水施工48小时后做闭水试验，地面蓄水3-5cm深，48小时后到楼下检查是否渗漏。只有试验合格才能进行下一步。"},{id:"mas-t4",text:"墙面瓷砖铺贴",detail:"卫生间和厨房墙面铺贴瓷砖，先铺墙砖再铺地砖（墙压地工艺）。瓷砖需提前泡水2小时以上（瓷片类），全瓷砖用瓷砖胶铺贴。"},{id:"mas-t5",text:"地面瓷砖铺贴",detail:"按照排版图铺贴地砖，注意留缝（一般1.5-2mm），找坡方向正确（卫生间向地漏方向、阳台向排水口方向）。"},{id:"mas-t6",text:"过门石安装",detail:"在不同地面材料交接处安装过门石，卫生间过门石下方要做防水翻边处理（挡水条），防止水顺着过门石底部渗到外面。"},{id:"mas-t7",text:"地漏安装",detail:"安装地漏时确保地面向地漏方向找坡，坡度约1%-2%。淋浴区建议用长条形地漏，其他区域用T型芯地漏。"},{id:"mas-t8",text:"瓷砖验收与美缝",detail:"检查瓷砖空鼓率（墙面≤5%，地面不允许空鼓），平整度和缝隙均匀度。铺贴完成后清理缝隙，准备美缝施工。"},{id:"mas-t9",text:"挡水条和窗台石安装",detail:"淋浴区挡水条在贴砖前预埋底部，窗台石可在贴砖时同步安装，注意窗台石要做防水处理并向外倾斜排水。"}],warnings:[{id:"mas-w1",title:"防水绝不能省",detail:"防水是装修中最不能省的工程。卫生间防水没做好，漏水到楼下要赔偿维修，砸掉地砖重做防水的成本是初次的3-5倍。"},{id:"mas-w2",title:"闭水试验必须做够48小时",detail:"有些工人只做24小时闭水试验就说合格，但慢渗漏需要更长时间才能发现。坚持做48小时，并亲自到楼下检查。"},{id:"mas-w3",title:"全瓷砖不能用水泥砂浆贴",detail:"全瓷砖（吸水率低于0.5%）用水泥砂浆贴不牢，必须用瓷砖胶。上墙的大砖还需要加挂铜丝或用背胶处理。"},{id:"mas-w4",title:"注意瓷砖排版",detail:"开工前做好瓷砖排版图，避免出现窄条砖（小于半砖宽度）。好的排版可以减少浪费且美观度大幅提升。"},{id:"mas-w5",title:"地漏位置不能在砖中间",detail:"地漏应放在整砖的交角处或紧贴墙边，放在砖中间需要对角切割，既不美观也容易积水。提前和瓦工沟通排版。"},{id:"mas-w6",title:"防水涂料不要选最便宜的",detail:"市面上防水涂料价格差异很大，建议选东方雨虹、德高、西卡等知名品牌的柔性防水涂料，性能远优于便宜杂牌。"}],shopping:[{id:"mas-s1",name:"防水涂料（柔性）",category:"防水材料",priceMin:200,priceMax:500,unit:"元/桶(18kg)",note:"建议选东方雨虹、德高、西卡等品牌，1kg约涂1.5-2㎡（两遍）"},{id:"mas-s2",name:"瓷砖（墙砖300×600）",category:"主材",priceMin:20,priceMax:80,unit:"元/㎡",note:"厨卫墙砖常用规格，建议选一线品牌副厂或二线品牌主厂"},{id:"mas-s3",name:"瓷砖（地砖800×800）",category:"主材",priceMin:40,priceMax:200,unit:"元/㎡",note:"客餐厅地砖常用规格，全抛釉价格较高但效果好"},{id:"mas-s4",name:"瓷砖（卫生间地砖300×300）",category:"主材",priceMin:15,priceMax:60,unit:"元/㎡",note:"卫生间地砖要选防滑砖，釉面哑光或仿古砖防滑效果好"},{id:"mas-s5",name:"瓷砖胶",category:"辅材",priceMin:30,priceMax:80,unit:"元/袋(20kg)",note:"全瓷砖上墙必须用瓷砖胶，一袋约贴3-5㎡"},{id:"mas-s6",name:"过门石（天然大理石）",category:"主材",priceMin:80,priceMax:250,unit:"元/条",note:"常用黑金花、印度红等石材，宽度与门框一致，厚度1.5-2cm"},{id:"mas-s7",name:"地漏（T型芯/磁悬浮）",category:"五金",priceMin:30,priceMax:150,unit:"元/个",note:"淋浴区建议用长条地漏，其他区域用T型芯地漏，防臭效果好"},{id:"mas-s8",name:"窗台石（人造石/大理石）",category:"主材",priceMin:150,priceMax:400,unit:"元/米",note:"按窗户长度计算，建议向外倾斜2-3度便于排水"},{id:"mas-s9",name:"挡水条",category:"五金",priceMin:40,priceMax:120,unit:"元/米",note:"天然石材或人造石材质，淋浴区干湿分离必备"},{id:"mas-s10",name:"美缝剂",category:"辅材",priceMin:25,priceMax:80,unit:"元/组（双管）",note:"一组约做3-5㎡，颜色选与瓷砖接近或反差大的效果好"},{id:"mas-s11",name:"水泥砂浆",category:"辅材",priceMin:25,priceMax:40,unit:"元/袋(50kg)",note:"铺贴非全瓷砖使用，配合河沙1:2.5比例"}],preparations:[{id:"mas-p1",text:"提前选购好瓷砖并确认到货时间，比计算用量多买5%-10%"},{id:"mas-p2",text:"确认水电已验收合格，管线已拍照存档"},{id:"mas-p3",text:"确定好地漏、过门石、挡水条的位置和尺寸"},{id:"mas-p4",text:"做好瓷砖排版图，避免出现窄条砖"},{id:"mas-p5",text:"购买好防水涂料并确认品牌型号"}],workerTypes:[{id:"mas-wk1",name:"泥瓦工/瓦工",priceType:"按面积计费",priceMin:40,priceMax:80,unit:"元/㎡",note:"普通规格瓷砖铺贴人工费，含地面找平"},{id:"mas-wk2",name:"泥瓦工（大砖/异形铺贴）",priceType:"按面积计费",priceMin:80,priceMax:150,unit:"元/㎡",note:"大于800×800的瓷砖或菱形、人字形等特殊铺法加价"},{id:"mas-wk3",name:"防水工",priceType:"按面积计费",priceMin:30,priceMax:60,unit:"元/㎡",note:"含防水涂刷和闭水试验，通常瓦工可兼做"},{id:"mas-wk4",name:"美缝师",priceType:"按面积计费",priceMin:15,priceMax:35,unit:"元/㎡",note:"瓷砖铺贴完成后做美缝，一般需瓷砖铺完一周后施工"}]},{id:"carpentry",name:"木工工程",icon:"🪚",order:5,description:"主要包括吊顶制作安装和定制柜体（如选择现场制作）。现在大部分柜体选择全屋定制，木工工作主要集中在吊顶。",duration:"1-2周",tasks:[{id:"car-t1",text:"客餐厅吊顶施工",detail:"根据设计图纸进行吊顶龙骨架设，轻钢龙骨优于木龙骨（不变形不生虫）。石膏板用自攻螺丝固定，螺丝间距15-20cm，板缝留3-5mm。"},{id:"car-t2",text:"厨卫吊顶准备",detail:"厨卫通常用铝扣板或蜂窝大板吊顶，此阶段先确认好高度和预埋件。铝扣板吊顶一般在后期安装阶段由商家施工。"},{id:"car-t3",text:"制作窗帘盒/窗帘滑道预留",detail:"如果选择窗帘盒隐藏轨道，需要在吊顶时预留窗帘盒位置，宽度至少15cm，深度根据窗帘层数确定（单层10cm，双层15cm）。"},{id:"car-t4",text:"全屋定制柜体复尺",detail:"墙面和地面基本完成后，联系定制家具厂家上门复尺（第二次测量），确认最终尺寸。复尺要在贴完砖或刷完漆后进行。"},{id:"car-t5",text:"制作电视背景墙造型",detail:"如设计有木饰面、石膏线条或格栅造型背景墙，由木工制作基层骨架并安装面板。注意预留电视挂架加固板。"},{id:"car-t6",text:"门套基层制作",detail:"如有需要，制作门套基层板（特别是非标准尺寸的门洞），确保门洞尺寸方正，为后续门安装做准备。"},{id:"car-t7",text:"检查吊顶质量",detail:"检查龙骨间距（主龙骨≤1200mm，副龙骨≤400mm），石膏板接缝处理，螺丝是否陷入板面1-2mm但不破纸面。"},{id:"car-t8",text:"预留灯具和设备开孔",detail:"吊顶时根据灯具和新风、中央空调出风口位置预留开孔和加固结构。筒灯和射灯位置要提前确认。"}],warnings:[{id:"car-w1",title:"轻钢龙骨优于木龙骨",detail:"木龙骨容易受潮变形和生虫，建议吊顶统一用轻钢龙骨。只有造型复杂的小面积区域才考虑用木龙骨辅助。"},{id:"car-w2",title:"石膏板接缝处理很关键",detail:"石膏板接缝不做V字缝处理、不贴嵌缝带，日后必然开裂。正确做法：留缝→填嵌缝石膏→贴网格带→再批嵌缝石膏。"},{id:"car-w3",title:"不建议做太复杂的吊顶",detail:"层高低于2.7米的房间不建议做大面积吊顶，会显得压抑。可以走一圈石膏线或做局部吊顶隐藏管线即可。"},{id:"car-w4",title:"全屋定制要注意板材环保等级",detail:"定制柜体板材至少选ENF级（甲醛释放≤0.025mg/m³），不要被商家用E0、E1等旧标准忽悠。要求商家出示板材检测报告。"},{id:"car-w5",title:"定制家具合同要写明所有细节",detail:"品牌、板材型号、五金品牌、门板材质、尺寸公差、交货期、安装费、售后保修等必须写进合同。口头承诺不算数。"}],shopping:[{id:"car-s1",name:"轻钢龙骨",category:"吊顶材料",priceMin:8,priceMax:20,unit:"元/米",note:"吊顶主骨架，选用国标0.6mm以上厚度的镀锌龙骨"},{id:"car-s2",name:"石膏板（9.5mm/12mm）",category:"吊顶材料",priceMin:25,priceMax:60,unit:"元/张(2.4×1.2m)",note:"建议选泰山、可耐福、圣戈班等品牌，卫生间用防水石膏板"},{id:"car-s3",name:"全屋定制柜体",category:"定制家具",priceMin:800,priceMax:2e3,unit:"元/投影面积㎡",note:"含衣柜、橱柜、鞋柜等，投影面积计价。中等品牌1000-1500元/㎡"},{id:"car-s4",name:"嵌缝石膏和网格带",category:"吊顶辅材",priceMin:15,priceMax:40,unit:"元/套",note:"石膏板接缝处理必备，防止后期开裂"},{id:"car-s5",name:"自攻螺丝",category:"吊顶辅材",priceMin:15,priceMax:30,unit:"元/盒(500个)",note:"固定石膏板用，3.5×25mm规格常用"},{id:"car-s6",name:"木饰面板",category:"造型材料",priceMin:80,priceMax:300,unit:"元/㎡",note:"电视背景墙或床头背景使用，PET膜板比实木贴皮性价比高"},{id:"car-s7",name:"石膏线条",category:"造型材料",priceMin:8,priceMax:25,unit:"元/米",note:"天花角线或墙面造型线，简单吊顶的平替方案"},{id:"car-s8",name:"铝扣板吊顶（厨卫）",category:"吊顶材料",priceMin:80,priceMax:200,unit:"元/㎡",note:"含龙骨和安装，蜂窝大板更美观但价格更高（150-350元/㎡）"}],preparations:[{id:"car-p1",text:"确认吊顶设计图纸和灯具点位"},{id:"car-p2",text:"中央空调、新风系统内机已安装到位"},{id:"car-p3",text:"确认全屋定制品牌和初步方案，完成首次量尺"},{id:"car-p4",text:"购买好吊顶所需轻钢龙骨和石膏板等材料"}],workerTypes:[{id:"car-wk1",name:"木工（吊顶）",priceType:"按面积计费",priceMin:50,priceMax:120,unit:"元/㎡",note:"简单平顶50-80元/㎡，复杂造型顶100-150元/㎡"},{id:"car-wk2",name:"木工（现场打柜子）",priceType:"按投影面积",priceMin:150,priceMax:300,unit:"元/㎡",note:"含制作人工费，不含板材。现场打柜质量取决于木工手艺"},{id:"car-wk3",name:"全屋定制安装工",priceType:"含在定制价格中",priceMin:0,priceMax:0,unit:"元",note:"全屋定制价格一般包含安装费，非标安装可能额外收费"}]},{id:"painting",name:"油漆工程",icon:"🎨",order:6,description:"墙面和天花板的涂装工程，包括基层处理、刮腻子、打磨、刷底漆和面漆。墙面效果好不好，七分靠腻子三分靠漆。",duration:"2-3周",tasks:[{id:"pai-t1",text:"墙面基层处理",detail:"检查墙面基层是否平整牢固，有空鼓松动的地方铲除重做。新砌墙体需要挂网处理，防止开裂。"},{id:"pai-t2",text:"刷墙固/界面剂",detail:"在基层上刷一遍墙固（界面剂），增强腻子与基层的附着力，防止后期起皮脱落。这一步不能省。"},{id:"pai-t3",text:"批刮腻子（2-3遍）",detail:"使用成品耐水腻子（非现场调配），批刮2-3遍，每遍厚度不超过1mm，每遍间隔需充分干透（至少24小时）。"},{id:"pai-t4",text:"打磨腻子",detail:"腻子干透后用240-360目砂纸打磨平整，打磨时注意戴口罩和护目镜。打磨后用强光手电检查平整度。"},{id:"pai-t5",text:"刷底漆（1遍）",detail:"底漆的作用是封闭基层、增强面漆附着力和抗碱性。全屋均匀涂刷一遍底漆，不能漏刷。底漆也要选好品牌。"},{id:"pai-t6",text:"刷面漆（2遍）",detail:"面漆刷2遍，每遍间隔至少4小时。刷漆时保持通风但避免强风直吹（会导致开裂），温度5°C以上施工。"},{id:"pai-t7",text:"修补和收口处理",detail:"检查所有阴角阳角是否顺直，有无流坠、起皮、针眼等问题。开关插座周围和门窗框边缘要仔细收口。"},{id:"pai-t8",text:"壁纸/壁布施工（如选用）",detail:"如果选择壁纸或壁布代替乳胶漆，需在腻子打磨后刷基膜，然后由专业壁纸师傅铺贴。注意对花和接缝处理。"}],warnings:[{id:"pai-w1",title:"一定要用成品耐水腻子",detail:"不要用工人现场用滑石粉+胶水调配的腻子，不环保且质量不稳定。选用美巢、百得、立邦批乐宝等成品耐水腻子，耐水防潮不易开裂。"},{id:"pai-w2",title:"底漆不能省",detail:"有些工人为赶工期会建议不刷底漆直接刷面漆，这样会导致面漆附着力差、容易起碱返白。底漆省几百块，后期翻修花几千。"},{id:"pai-w3",title:"腻子必须干透再刷漆",detail:"腻子没干透就着急刷漆，水分被封在墙里，日后必然起泡脱皮。梅雨季节每遍腻子至少等48小时，冬天等72小时。"},{id:"pai-w4",title:"乳胶漆颜色会有色差",detail:"电脑调色与实际上墙效果会有色差，建议先小面积试刷确认。深色漆需要多刷1-2遍才能均匀，且补漆容易出现明显色差。"},{id:"pai-w5",title:"刷漆期间注意温湿度",detail:"温度低于5°C或湿度高于85%不建议施工。冬季北方有暖气时注意室内太干会导致漆面干裂，可放盆水增加湿度。"}],shopping:[{id:"pai-s1",name:"成品耐水腻子",category:"基层材料",priceMin:30,priceMax:80,unit:"元/袋(20kg)",note:"建议选美巢800、百得、立邦批乐宝，1袋约批8-12㎡（两遍）"},{id:"pai-s2",name:"墙固/界面剂",category:"基层材料",priceMin:50,priceMax:150,unit:"元/桶(5kg)",note:"增强腻子附着力，1桶约刷40-60㎡"},{id:"pai-s3",name:"乳胶漆（底漆）",category:"涂料",priceMin:200,priceMax:500,unit:"元/桶(5L)",note:"建议选多乐士、立邦、芬琳、舒纳沃恩等品牌，1桶约刷50-70㎡"},{id:"pai-s4",name:"乳胶漆（面漆）",category:"涂料",priceMin:300,priceMax:800,unit:"元/桶(5L)",note:"100㎡房屋约需3-4桶面漆，选无添加或儿童漆系列更环保"},{id:"pai-s5",name:"网格布/接缝带",category:"辅材",priceMin:3,priceMax:8,unit:"元/米",note:"新旧墙交接处、石膏板接缝处必须贴网格布防裂"},{id:"pai-s6",name:"砂纸（240-360目）",category:"辅材",priceMin:1,priceMax:3,unit:"元/张",note:"腻子打磨用，240目粗磨，360目细磨"},{id:"pai-s7",name:"壁纸/壁布",category:"墙面材料",priceMin:30,priceMax:200,unit:"元/㎡",note:"含铺贴费用则在60-300元/㎡，无纺布壁纸性价比高"},{id:"pai-s8",name:"基膜",category:"壁纸辅材",priceMin:80,priceMax:200,unit:"元/桶(5L)",note:"贴壁纸前必须刷基膜，保护墙面并方便日后更换壁纸"},{id:"pai-s9",name:"石膏粉",category:"基层材料",priceMin:15,priceMax:35,unit:"元/袋(20kg)",note:"找平修补用，大面积不平需先用石膏找平再批腻子"}],preparations:[{id:"pai-p1",text:"确认吊顶和木工工程已完成并验收"},{id:"pai-p2",text:"购买好腻子、乳胶漆等材料（注意色号确认）"},{id:"pai-p3",text:"做好地面和门窗的保护，铺好保护膜"},{id:"pai-p4",text:"如选用壁纸壁布，确认款式并下单（壁纸需提前到货）"}],workerTypes:[{id:"pai-wk1",name:"油漆工/墙面工",priceType:"按面积计费",priceMin:18,priceMax:35,unit:"元/㎡",note:"含刮腻子2-3遍+底漆1遍+面漆2遍，100㎡房约250-300㎡墙面面积"},{id:"pai-wk2",name:"壁纸/壁布铺贴工",priceType:"按面积计费",priceMin:15,priceMax:40,unit:"元/㎡",note:"含基膜涂刷和壁纸铺贴，复杂花型对花另加费用"},{id:"pai-wk3",name:"油漆工（按天）",priceType:"按天计费",priceMin:300,priceMax:500,unit:"元/天",note:"小面积或特殊工艺按天计费可能更合适"}]},{id:"installation",name:"主材安装",icon:"🚪",order:7,description:"进入主材集中安装阶段，包括地板、室内门、橱柜、卫浴洁具、灯具、开关插座等的安装。需要合理安排各工种进场顺序。",duration:"2-3周",tasks:[{id:"ins-t1",text:"厨卫吊顶安装",detail:"铝扣板或蜂窝大板吊顶安装，同步安装厨卫照明灯具、排风扇、浴霸等。先装吊顶再装橱柜和卫浴。"},{id:"ins-t2",text:"橱柜安装",detail:"整体橱柜安装包括地柜、吊柜、台面、五金件。安装前确认水电位置准确，安装后检查柜门平整度和开合顺畅度。"},{id:"ins-t3",text:"室内门安装",detail:"门扇、门框、门套一起安装，注意门缝上方3mm，左右2-3mm，下方门吸侧5-8mm。门锁和合页选用静音款使用体验更好。"},{id:"ins-t4",text:"地板铺设",detail:"木地板铺设前地面必须干燥平整（含水率≤20%），需提前3天将地板放入房间适应温湿度。实木地板需打龙骨，强化/多层可直铺。"},{id:"ins-t5",text:"卫浴洁具安装",detail:"安装马桶、浴室柜、花洒、毛巾架、纸巾架等。马桶安装注意坑距（300mm或400mm），法兰圈要选加厚防臭型。"},{id:"ins-t6",text:"开关插座面板安装",detail:"安装全屋开关插座面板，建议统一品牌和系列保持美观。安装后逐个测试通电是否正常，插座用验电器检查接线是否正确。"},{id:"ins-t7",text:"灯具安装",detail:"安装全屋灯具包括主灯、射灯、筒灯、灯带等。重量较大的灯具（>3kg）需确认吊顶有加固处理。"},{id:"ins-t8",text:"五金挂件安装",detail:"安装厨卫五金挂件（毛巾杆、浴巾架、置物架、挂钩等），打孔前用探测器确认墙内无水管电线。"},{id:"ins-t9",text:"热水器和厨电安装",detail:"安装燃气热水器或电热水器、油烟机、燃气灶、蒸烤一体机等厨房电器。燃气设备必须由燃气公司或授权人员安装。"},{id:"ins-t10",text:"安装踢脚线和收口条",detail:"木地板配套踢脚线由地板商家安装，瓷砖踢脚线由泥工铺贴。不同地面材料交接处安装收口条。"}],warnings:[{id:"ins-w1",title:"安装顺序很重要",detail:"建议顺序：厨卫吊顶→橱柜→木门→地板→卫浴→开关插座→灯具→五金挂件→窗帘。顺序错了容易磕碰已安装的成品。"},{id:"ins-w2",title:"木门要提前1个月下单",detail:"木门从下单到安装一般需要30-45天制作周期，不提前定好会严重耽误工期。量门在泥工完成后进行。"},{id:"ins-w3",title:"地板铺设前必须做地面含水率检测",detail:"地面含水率过高会导致地板起拱变形。建议地面做完至少2-3周后再铺地板，有条件用含水率测量仪检测。"},{id:"ins-w4",title:"马桶安装后24小时内不要使用",detail:"马桶用玻璃胶固定后需要24小时以上才能完全固化，提前使用会导致密封不严、后期松动甚至漏水。"},{id:"ins-w5",title:"开关插座安装后逐个测试",detail:"安装完成后用验电器逐个检测插座，确认火线零线地线接线正确。接线错误可能导致漏电甚至触电风险。"},{id:"ins-w6",title:"五金件不要贪便宜",detail:"铰链、滑轨、门锁等五金件直接影响使用寿命和体验。建议选百隆、海蒂诗、DTC等品牌，每天使用频率最高的地方最不能省。"}],shopping:[{id:"ins-s1",name:"强化复合地板",category:"地面材料",priceMin:80,priceMax:200,unit:"元/㎡",note:"含踢脚线和安装费，耐磨层≥AC4级，建议选12mm厚度"},{id:"ins-s2",name:"多层实木地板",category:"地面材料",priceMin:200,priceMax:450,unit:"元/㎡",note:"含安装费，稳定性好适合地暖，推荐品牌：大自然、圣象、生活家"},{id:"ins-s3",name:"实木门（含门套）",category:"门类",priceMin:1500,priceMax:4e3,unit:"元/樘",note:"含门套、锁具、合页，实木复合门性价比最高，纯实木门更贵"},{id:"ins-s4",name:"卫生间门（铝合金/钛镁合金）",category:"门类",priceMin:800,priceMax:2e3,unit:"元/樘",note:"卫生间建议用铝合金门防潮，含五金件和安装"},{id:"ins-s5",name:"马桶（虹吸式）",category:"卫浴",priceMin:800,priceMax:3e3,unit:"元/个",note:"建议选TOTO、科勒、箭牌等品牌，智能马桶盖可后期加装"},{id:"ins-s6",name:"浴室柜",category:"卫浴",priceMin:800,priceMax:3e3,unit:"元/套",note:"含柜体、镜柜、龙头，选实木/多层板材质，PVC材质更便宜"},{id:"ins-s7",name:"花洒套装",category:"卫浴",priceMin:300,priceMax:1500,unit:"元/套",note:"含顶喷、手持、龙头和升降杆，建议选铜芯阀体"},{id:"ins-s8",name:"开关插座面板",category:"电气",priceMin:5,priceMax:30,unit:"元/个",note:"全屋约需50-80个，建议选西门子、施耐德、公牛、德力西等品牌"},{id:"ins-s9",name:"客厅主灯",category:"灯具",priceMin:300,priceMax:2e3,unit:"元/个",note:"简约吸顶灯或无主灯筒灯方案，注意色温选3000-4000K舒适区间"},{id:"ins-s10",name:"筒灯/射灯",category:"灯具",priceMin:15,priceMax:60,unit:"元/个",note:"无主灯方案全屋约需20-40个，选防眩光款，7-12W功率为主"},{id:"ins-s11",name:"油烟机+燃气灶套装",category:"厨电",priceMin:2e3,priceMax:6e3,unit:"元/套",note:"侧吸油烟机排烟效果好，灶具选大火力（≥5.0kW）"},{id:"ins-s12",name:"燃气热水器（13L/16L）",category:"热水设备",priceMin:1500,priceMax:4e3,unit:"元/台",note:"13L适合一厨一卫，16L适合一厨两卫，建议选零冷水功能"},{id:"ins-s13",name:"水槽+龙头套装",category:"厨房",priceMin:500,priceMax:2e3,unit:"元/套",note:"建议选304不锈钢大单槽，手工槽质量优于拉伸槽"},{id:"ins-s14",name:"浴霸/风暖",category:"卫浴电器",priceMin:300,priceMax:1200,unit:"元/台",note:"建议选风暖型而非灯暖型，取暖+换气+照明多功能合一"}],preparations:[{id:"ins-p1",text:"确认所有主材已到货并检查数量和质量"},{id:"ins-p2",text:"确认墙面和地面施工已完成并充分干燥"},{id:"ins-p3",text:"排好各工种进场安装的先后顺序"},{id:"ins-p4",text:"预约好各商家的安装时间，至少提前一周"},{id:"ins-p5",text:"做好已完工区域的成品保护"}],workerTypes:[{id:"ins-wk1",name:"地板安装工",priceType:"含在地板价格中",priceMin:0,priceMax:30,unit:"元/㎡",note:"大部分品牌地板含免费安装，复杂地形或非标准安装额外收费"},{id:"ins-wk2",name:"门安装工",priceType:"含在门价格中",priceMin:0,priceMax:0,unit:"元",note:"门的价格一般含安装，异形门洞或非标安装另收费"},{id:"ins-wk3",name:"卫浴安装工",priceType:"按件计费",priceMin:50,priceMax:200,unit:"元/件",note:"马桶安装50-100元，浴室柜安装100-200元，花洒安装50-100元"},{id:"ins-wk4",name:"灯具安装工",priceType:"按个计费",priceMin:10,priceMax:80,unit:"元/个",note:"简单吸顶灯10-30元，复杂吊灯50-100元，射灯筒灯10-15元"},{id:"ins-wk5",name:"厨电安装工",priceType:"含在商品价格中",priceMin:0,priceMax:0,unit:"元",note:"油烟机、燃气灶、热水器等一般含免费安装"}]},{id:"furnishing",name:"软装家电",icon:"🛋️",order:8,description:"硬装完成后进行软装布置和家电购置，包括家具采购、窗帘定制、家电选购和装饰搭配。软装决定了家的最终风格和舒适度。",duration:"2-4周",tasks:[{id:"fur-t1",text:"采购客厅家具",detail:"选购沙发、茶几、电视柜等客厅主要家具。沙发是客厅灵魂，建议到实体店试坐体验舒适度，关注坐垫填充材质和框架用材。"},{id:"fur-t2",text:"采购卧室家具",detail:"选购床架、床垫、床头柜、梳妆台等。床垫建议选独立弹簧+乳胶/记忆棉，一定要到店试躺。床架建议选排骨架而非硬板。"},{id:"fur-t3",text:"采购餐厅家具",detail:"选购餐桌、餐椅、餐边柜等。餐桌大小根据家庭人数选择（4人1.2-1.4m，6人1.6-1.8m），实木桌比岩板桌维护更方便。"},{id:"fur-t4",text:"定制窗帘",detail:"根据窗户尺寸定制窗帘，建议窗帘宽度为窗户宽度的1.5-2倍形成褶皱。卧室选遮光率95%以上的遮光帘，客厅可用纱帘+布帘双层。"},{id:"fur-t5",text:"选购主要家电",detail:"选购冰箱、洗衣机、空调（如非中央空调）、电视、洗碗机等。注意家电尺寸与预留空间的匹配，特别是冰箱和洗衣机。"},{id:"fur-t6",text:"选购小家电",detail:"根据生活需求选购扫地机器人、空气净化器、净水器、烤箱、咖啡机、破壁机等小家电。不要冲动购买，按实际需求选择。"},{id:"fur-t7",text:"装饰品搭配",detail:"选购挂画、绿植、花瓶、抱枕、地毯等装饰品，提升家居质感。装饰品颜色建议与整体风格协调，遵循主色60%+辅色30%+点缀色10%原则。"},{id:"fur-t8",text:"收纳用品购置",detail:"根据各空间收纳需求购买收纳盒、衣架、鞋盒、抽屉分隔件等。入住前做好收纳规划可以让家长期保持整洁。"}],warnings:[{id:"fur-w1",title:"家具尺寸一定要量好",detail:"网上买家具最常见的问题就是尺寸不合适。买之前务必用卷尺量好空间，预留走道宽度（至少60cm），大件家具考虑能否进电梯和入户门。"},{id:"fur-w2",title:"床垫不要网上盲买",detail:"床垫是最影响睡眠质量的家具，个人体感差异很大。一定要到实体店试躺至少10分钟。偏硬偏软因人而异，不要听信网上一边倒的推荐。"},{id:"fur-w3",title:"家电要预留散热空间",detail:"嵌入式冰箱、洗碗机、烤箱等需要预留足够的散热空间（通常两侧各2-5cm，上方5-10cm），否则影响使用寿命甚至有安全隐患。"},{id:"fur-w4",title:"窗帘选购注意事项多",detail:"窗帘水很深，注意辅料费用（铅坠、绑带、挂钩、轨道等）可能超过布料本身的价格。提前问清楚总价包含哪些项目。"},{id:"fur-w5",title:"不要一次买齐所有东西",detail:"入住后才知道真正需要什么。建议先购置必需品（床、沙发、餐桌、冰箱、洗衣机），其他慢慢添置，避免冲动消费买了闲置。"}],shopping:[{id:"fur-s1",name:"沙发（三人位）",category:"客厅家具",priceMin:3e3,priceMax:15e3,unit:"元/套",note:"布艺沙发3000-8000元，皮沙发5000-15000元，科技布是性价比之选"},{id:"fur-s2",name:"床架（1.8m×2m）",category:"卧室家具",priceMin:2e3,priceMax:8e3,unit:"元/张",note:"实木床架更环保耐用，板式床注意甲醛释放。排骨架优于硬板"},{id:"fur-s3",name:"床垫（1.8m×2m）",category:"卧室家具",priceMin:1500,priceMax:8e3,unit:"元/张",note:"独立袋装弹簧+乳胶层组合最常见，一定要试躺体验"},{id:"fur-s4",name:"餐桌+餐椅套装",category:"餐厅家具",priceMin:2e3,priceMax:8e3,unit:"元/套",note:"实木餐桌+4-6椅套装，岩板桌面价格更高但颜值高"},{id:"fur-s5",name:"窗帘（含轨道安装）",category:"软装",priceMin:80,priceMax:300,unit:"元/米",note:"指每米窗帘展开宽度价格，含布料+纱+轨道+辅料+安装"},{id:"fur-s6",name:"冰箱（十字对开门/法式多门）",category:"大家电",priceMin:3e3,priceMax:1e4,unit:"元/台",note:"容量400-500L适合3-5口之家，建议选一级能效变频压缩机"},{id:"fur-s7",name:"洗烘一体机/洗烘套装",category:"大家电",priceMin:2500,priceMax:8e3,unit:"元/台",note:"洗烘套装效果优于一体机，热泵烘干优于冷凝烘干"},{id:"fur-s8",name:"空调（挂机1.5匹）",category:"大家电",priceMin:2e3,priceMax:5e3,unit:"元/台",note:"每个卧室一台，选一级能效变频，新一级比旧一级更省电"},{id:"fur-s9",name:"电视（65-75寸）",category:"大家电",priceMin:2500,priceMax:8e3,unit:"元/台",note:"客厅建议65寸起步，3米观看距离选75寸。MiniLED画质好"},{id:"fur-s10",name:"洗碗机（嵌入式13套）",category:"厨电",priceMin:3e3,priceMax:7e3,unit:"元/台",note:"装修时预留好水电位和橱柜空间，13套容量适合4口之家"},{id:"fur-s11",name:"扫地机器人",category:"小家电",priceMin:1500,priceMax:4e3,unit:"元/台",note:"选扫拖一体+自动集尘+自清洁功能，解放双手必备"},{id:"fur-s12",name:"挂画/装饰画",category:"装饰品",priceMin:50,priceMax:500,unit:"元/幅",note:"客厅沙发背景墙或餐厅挂画，注意与整体风格搭配"}],preparations:[{id:"fur-p1",text:"硬装全部完成并做好保洁清理"},{id:"fur-p2",text:"测量好各区域的家具摆放空间和通道宽度"},{id:"fur-p3",text:"确认入户门和电梯尺寸，大件家具能否搬入"},{id:"fur-p4",text:"确定好家电嵌入尺寸，特别是冰箱和洗碗机"},{id:"fur-p5",text:"制定软装采购清单和预算，避免冲动消费"}],workerTypes:[{id:"fur-wk1",name:"家具配送安装工",priceType:"含在商品价格中",priceMin:0,priceMax:0,unit:"元",note:"大部分品牌家具含免费配送安装，送货上门前确认电梯能否容纳"},{id:"fur-wk2",name:"窗帘安装工",priceType:"含在窗帘价格中",priceMin:0,priceMax:50,unit:"元/套",note:"窗帘价格通常含安装，复杂窗型或电动轨道可能额外收费"},{id:"fur-wk3",name:"家电安装工",priceType:"含在商品价格中",priceMin:0,priceMax:0,unit:"元",note:"品牌家电含免费安装，但空调安装高空作业费等可能另收"},{id:"fur-wk4",name:"挂画/装饰安装",priceType:"自行安装或按次收费",priceMin:0,priceMax:100,unit:"元/次",note:"简单挂画可自行安装，复杂造型墙饰建议请师傅安装"}]},{id:"inspection",name:"收尾验收",icon:"✅",order:9,description:"装修最后阶段，包括开荒保洁、全面质量验收、问题整改和通风散味。验收要细致认真，发现问题及时整改。",duration:"1-2周（通风建议3-6个月）",tasks:[{id:"ins9-t1",text:"开荒保洁",detail:"请专业保洁团队进行开荒保洁，包括玻璃清洁、地面清洗、卫浴清洁、灰尘清理等。自己做也可以但非常耗时。"},{id:"ins9-t2",text:"水路验收检查",detail:"打开所有水龙头检查水流和水压，检查所有下水是否通畅（接一盆水快速倒入），检查角阀和管道接口有无渗漏。"},{id:"ins9-t3",text:"电路验收检查",detail:"逐个测试所有开关和插座是否正常工作，使用验电器检查插座接线，测试配电箱各回路漏电保护器是否正常跳闸。"},{id:"ins9-t4",text:"瓷砖和地板验收",detail:"用空鼓锤逐块检查瓷砖空鼓（墙砖空鼓率≤5%，地砖不允许空鼓），检查地板是否有起翘、异响、划痕。"},{id:"ins9-t5",text:"墙面验收",detail:"在自然光和灯光下检查墙面平整度、有无开裂起皮、颜色是否均匀、阴阳角是否顺直。用靠尺检查平整度偏差≤3mm。"},{id:"ins9-t6",text:"门窗验收",detail:"检查所有门窗开关是否顺畅、密封是否严密、锁具是否正常、门缝是否均匀。窗户检查五金件、密封胶条和排水孔。"},{id:"ins9-t7",text:"编制整改清单并跟进",detail:"将验收中发现的所有问题列成清单，拍照标注，要求施工方在约定时间内整改。每个问题逐一确认整改合格后签字。"},{id:"ins9-t8",text:"甲醛检测和通风除醛",detail:"请CMA认证的专业检测机构做甲醛检测（自测盒不准确）。保持通风3-6个月，室内温度越高甲醛释放越快，夏天通风效果最好。"},{id:"ins9-t9",text:"整理装修档案",detail:"整理保存所有装修合同、保修卡、发票、水电走向图、产品说明书等资料。这些在日后维修、理赔时非常重要。"},{id:"ins9-t10",text:"支付尾款并确认保修",detail:"全部验收合格并整改完毕后支付尾款（通常为总价的5%-10%），确认保修起始日期和保修范围（一般隐蔽工程保修5年，其他2年）。"}],warnings:[{id:"ins9-w1",title:"尾款一定要验收合格后再付",detail:"尾款是你最大的筹码。一旦全部付清，施工方整改的积极性会大幅降低。留5%-10%尾款作为质保金，约定保修期满后付清。"},{id:"ins9-w2",title:"甲醛检测不要用自测盒",detail:"网上几十块钱的甲醛自测盒准确度极低。建议花300-500元请CMA认证的专业检测机构上门检测，结果有法律效力。"},{id:"ins9-w3",title:"通风时间不能省",detail:"即使检测合格也建议通风3个月以上。甲醛释放周期长达3-15年，持续通风是最有效的除醛方式。活性炭和绿植作用有限。"},{id:"ins9-w4",title:"验收时要在不同光线下检查",detail:"白天自然光和晚上灯光下墙面和地面的效果不同。分别在两种光线下检查，才能发现所有问题。"},{id:"ins9-w5",title:"保留所有购物凭证和合同",detail:"装修材料和家电的发票、保修卡、合同都要妥善保管。建议拍照备份到云端。出了质量问题这些是维权的重要凭证。"},{id:"ins9-w6",title:"开荒保洁要在家具入场前做",detail:"开荒保洁应在硬装完成、家具入场之前进行。家具进场后再做保洁会事倍功半，且容易磕碰新家具。"}],shopping:[{id:"ins9-s1",name:"开荒保洁服务",category:"服务",priceMin:3,priceMax:8,unit:"元/㎡",note:"100㎡房屋约300-800元，包含擦窗、拖地、卫浴清洁等"},{id:"ins9-s2",name:"甲醛专业检测（CMA认证）",category:"服务",priceMin:150,priceMax:300,unit:"元/检测点",note:"每个房间至少一个检测点，3室约需4-5个点位，结果具有法律效力"},{id:"ins9-s3",name:"空气净化器",category:"家电",priceMin:1e3,priceMax:4e3,unit:"元/台",note:"选带HEPA+活性炭滤网的，CADR值≥400m³/h适合20-30㎡房间"},{id:"ins9-s4",name:"甲醛检测仪（家用）",category:"工具",priceMin:100,priceMax:500,unit:"元/个",note:"作为日常参考可以，精确度不如专业检测，选带电化学传感器的"},{id:"ins9-s5",name:"活性炭包",category:"除醛用品",priceMin:30,priceMax:100,unit:"元/箱",note:"放置在柜体内辅助吸附，需定期更换（2-3个月），效果有限"},{id:"ins9-s6",name:"验电器/相位检测仪",category:"工具",priceMin:20,priceMax:80,unit:"元/个",note:"检测插座接线是否正确，必备验收工具"},{id:"ins9-s7",name:"空鼓锤",category:"工具",priceMin:10,priceMax:30,unit:"元/个",note:"检测瓷砖空鼓用，也可用硬币敲击代替"}],preparations:[{id:"ins9-p1",text:"所有施工项目已完成，无遗留未完工项目"},{id:"ins9-p2",text:"准备好验收工具：卷尺、水平尺、验电器、空鼓锤等"},{id:"ins9-p3",text:"准备好装修合同和设计图纸，对照验收"},{id:"ins9-p4",text:"预约好开荒保洁和甲醛检测时间"},{id:"ins9-p5",text:"准备好整改清单模板，方便记录问题"}],workerTypes:[{id:"ins9-wk1",name:"保洁人员",priceType:"按面积计费",priceMin:3,priceMax:8,unit:"元/㎡",note:"开荒保洁比日常保洁价格高，100㎡约需2-3人工作一天"},{id:"ins9-wk2",name:"甲醛检测工程师",priceType:"按检测点计费",priceMin:150,priceMax:300,unit:"元/点",note:"CMA认证机构出具正式检测报告，一般3-5个工作日出结果"},{id:"ins9-wk3",name:"第三方验房师/监理",priceType:"按面积计费",priceMin:5,priceMax:15,unit:"元/㎡",note:"专业验房师帮助检查装修质量，出具验收报告和整改建议"}]}],BUDGET_TEMPLATES={economic:{name:"经济型",description:"满足基本居住需求，性价比优先，选择国产主流品牌，简约设计风格",pricePerSqm:800,breakdown:{preparation:.02,demolition:.05,plumbing_electrical:.15,masonry:.15,carpentry:.1,painting:.08,installation:.2,furnishing:.2,inspection:.05}},comfortable:{name:"舒适型",description:"注重生活品质，材料中档以上，选择知名品牌，兼顾美观与实用",pricePerSqm:1500,breakdown:{preparation:.03,demolition:.04,plumbing_electrical:.14,masonry:.14,carpentry:.12,painting:.08,installation:.2,furnishing:.2,inspection:.05}},premium:{name:"品质型",description:"追求高品质生活，进口或一线品牌材料，精细工艺，个性化设计",pricePerSqm:2500,breakdown:{preparation:.04,demolition:.03,plumbing_electrical:.13,masonry:.13,carpentry:.12,painting:.07,installation:.22,furnishing:.22,inspection:.04}}},DEFAULT_BUDGET_ITEMS=[{id:"bi-prep-1",stageId:"preparation",name:"设计费",estimatedCost:0},{id:"bi-prep-2",stageId:"preparation",name:"装修许可及押金",estimatedCost:0},{id:"bi-prep-3",stageId:"preparation",name:"垃圾清运费",estimatedCost:0},{id:"bi-prep-4",stageId:"preparation",name:"量房及测量工具",estimatedCost:0},{id:"bi-demo-1",stageId:"demolition",name:"拆除人工费",estimatedCost:0},{id:"bi-demo-2",stageId:"demolition",name:"砌墙材料及人工",estimatedCost:0},{id:"bi-demo-3",stageId:"demolition",name:"门窗更换",estimatedCost:0},{id:"bi-demo-4",stageId:"demolition",nam